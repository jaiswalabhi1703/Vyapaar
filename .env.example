# Copy to `.env` (gitignored) for local dev, or set these as secrets in your deploy platform.
# NEVER commit real values.

# --- PayU (payment-service) ---
# Test merchant credentials live at https://onboarding.payu.in/ (test mode).
PAYU_KEY=
PAYU_SALT=
PAYU_PAYMENT_URL=https://test.payu.in/_payment
# Public URLs PayU redirects the browser back to. In the cloud these are your deployed
# payment-service URL; the frontend-return URL is your deployed SPA origin.
PAYU_SURL=http://localhost:8083/payments/payu/callback
PAYU_FURL=http://localhost:8083/payments/payu/callback
PAYU_RETURN_URL=http://localhost:5173

# --- Gateway ---
# Use a long random value in production.
JWT_SECRET=change-me-in-prod-this-is-a-demo-secret-key-0123456789

# --- Infra (override when not on localhost) ---
KAFKA_BOOTSTRAP=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Frontend (build-time) ---
# Base URL of the API gateway the SPA talks to.
VITE_API_BASE=http://localhost:8080
