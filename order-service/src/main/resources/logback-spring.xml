<?xml version="1.0" encoding="UTF-8"?>
<!--
  Correlation-ID logging. Every saga transition log line carries [sagaId=...] via MDC, so one
  order's whole journey through the orchestrator is greppable:  grep 'sagaId=saga-42' app.log
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [sagaId=%X{sagaId:-none}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
